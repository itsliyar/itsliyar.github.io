  <script>
    // Simple reveal animation
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(()=> {
        document.querySelectorAll('.fade-up').forEach(el => el.classList.add('show'));
      }, 120);

      // Tile interaction: click or keyboard to toggle content panels
      const tiles = document.querySelectorAll('.tile');
      tiles.forEach(tile => {
        tile.addEventListener('click', () => activateTile(tile));
        tile.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activateTile(tile); }
        });
      });

      function activateTile(tile) {
        // deactivate all
        tiles.forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tile-content').forEach(c => { c.classList.remove('show'); c.setAttribute('aria-hidden','true'); });

        // activate selected
        tile.classList.add('active');
        const target = tile.getAttribute('data-target');
        const panel = document.getElementById(target);
        if (panel) { panel.classList.add('show'); panel.setAttribute('aria-hidden','false'); }
      }

      // default: activate first tile
      if (tiles.length) activateTile(tiles[0]);
    });
  </script>
