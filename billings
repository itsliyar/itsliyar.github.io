<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>2-Wheeler Sale Bill</title>
  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f8f9fc;
      margin: 0;
      padding: 10px;
      color: #222;
    }

    .page {
      max-width: 940px;
      margin: auto;
      background: #fff;
      padding: 14px;
      border-radius: 8px;
      box-shadow: 0 3px 8px rgba(0,0,0,0.05);
    }

    .header {
      text-align: center;
      background: linear-gradient(to right, #d32f2f, #388e3c);
      color: white;
      padding: 8px;
      border-radius: 6px;
      font-size: 1em;
      margin-bottom: 8px;
    }

    .meta {
      display: flex;
      justify-content: space-between;
      font-size: 0.9em;
      margin: 5px 0 10px;
      color: #555;
    }

    h3 {
      font-size: 1em;
      color: #388e3c;
      margin: 12px 0 6px;
      border-bottom: 1px solid #ccc;
    }

    label {
      font-weight: 600;
      display: block;
      margin-bottom: 3px;
    }

    input, textarea {
      width: 100%;
      padding: 5px;
      border: 1px solid #bbb;
      border-radius: 5px;
      background: #fcfcfc;
      font-size: 0.9em;
      margin-bottom: 8px;
    }

    .manual-bill {
      border: none;
      border-bottom: 1px dashed #999;
      background: none;
      width: 150px;
      font-size: 0.9em;
    }

    .split {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
    }

    .column {
      flex: 1;
      min-width: 240px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 8px;
    }

    .row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .field {
      flex: 1;
      min-width: 140px;
    }

    .terms {
      font-size: 0.85em;
      background: #f7f7f7;
      border: 1px solid #ccc;
      padding: 8px;
      border-radius: 4px;
      line-height: 1.3;
    }

    button {
      background: #388e3c;
      color: white;
      padding: 6px 14px;
      border: none;
      border-radius: 4px;
      font-size: 0.9em;
      cursor: pointer;
      margin-top: 10px;
      margin-right: 8px;
    }

    .footer {
      text-align: center;
      margin-top: 12px;
      font-size: 0.85em;
      color: #888;
    }

    @media print {
      button { display: none; }
      body { zoom: 85%; margin: 0; }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="header">
      <strong>SuperTech Vehicle Dealership</strong><br>
      987 Motorway Lane, Bengaluru South • 📞 +91 98765 43210 • ✉️ vehicles@supertech.com
    </div>

    <div class="meta">
      <div>Bill No: <input type="text" class="manual-bill" name="billNumber" /></div>
      <div>Date: <script>document.write(new Date().toLocaleDateString());</script></div>
    </div>

    <form id="saleForm">
      <h3>Buyer & Seller Information</h3>
      <div class="split">
        <div class="column">
          <label>Seller Name:</label><input type="text" name="sellerName">
          <label>Contact:</label><input type="text" name="sellerContact">
          <label>Address:</label><textarea name="sellerAddress" rows="2"></textarea>
          <label>POIA:</label><input type="text" name="sellerPOIA">
        </div>
        <div class="column">
          <label>Buyer Name:</label><input type="text" name="buyerName">
          <label>Contact:</label><input type="text" name="buyerContact">
          <label>Address:</label><textarea name="buyerAddress" rows="2"></textarea>
          <label>POIA:</label><input type="text" name="buyerPOIA">
        </div>
      </div>

      <h3>Vehicle Information</h3>
      <div class="grid">
        <div><label>Make:</label><input type="text" name="make"></div>
        <div><label>Model:</label><input type="text" name="model"></div>
        <div><label>Year:</label><input type="number" name="year"></div>
        <div><label>Reg No.:</label><input type="text" name="regNo"></div>
        <div><label>Chassis No.:</label><input type="text" name="chassisNo"></div>
        <div><label>Engine No.:</label><input type="text" name="engineNo"></div>
        <div><label>Fuel Type:</label><input type="text" name="fuelType"></div>
        <div><label>Color:</label><input type="text" name="color"></div>
        <div><label>Condition:</label><input type="text" name="condition"></div>
        <div><label>Kilometers:</label><input type="text" name="kilometers"></div>
      </div>

      <h3>Payment Summary</h3>
      <div class="grid">
        <div><label>Advance:</label><input type="number" name="advance"></div>
        <div><label>Balance:</label><input type="number" name="balance"></div>
        <div><label>Commission:</label><input type="number" name="commission"></div>
        <div><label>Transfer Fee:</label><input type="number" name="transferFee"></div>
        <div><label>Total Amount:</label><input type="number" name="totalAmount"></div>
        <div><label>Payment Method:</label><input type="text" name="paymentMethod"></div>
        <div><label>Status:</label><input type="text" name="status"></div>
      </div>

      <h3>Terms & Conditions</h3>
      <div class="terms">
        Buyer confirms inspection and accepts the second-hand vehicle in its current condition.  
        No warranties are offered by the seller.  
        All insurance, taxes, and penalties are the buyer's responsibility.  
        Seller is not liable for mechanical issues after transfer.  
        Buyer agrees to register the vehicle within the applicable legal timeframe.
      </div>

      <h3>Signatures</h3>
      <div class="row">
        <div class="field"><label>Buyer:</label><input type="text" name="buyerSignature"></div>
        <div class="field"><label>Seller:</label><input type="text" name="sellerSignature"></div>
        <div class="field"><label>Witness:</label><input type="text" name="witnessSignature"></div>
        <div class="field"><label>Date:</label><input type="date" name="signatureDate"></div>
      </div>

      <button type="button" onclick="window.print()">🖨️ Print</button>
      <button type="submit">📤 Save to Google Sheets</button>
    </form>

    <div class="footer">
      &copy; SuperTech Vehicle Dealership — Efficient • Compact • Reliable
    </div>
  </div>

    <script>
    document.getElementById("saleForm").addEventListener("submit", function(e) {
      e.preventDefault();
      const formData = new FormData(this);
      const params = new URLSearchParams(formData).toString();

      fetch("YOUR_GOOGLE_SCRIPT_WEB_APP_URL", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: params
      })
      .then(response => {
        if (response.ok) {
          alert("✅ Information saved to Google Sheets.");
        } else {
          alert("❌ Error saving data. Please check the script and URL.");
        }
      })
      .catch(error => alert("⚠️ Network error. Check your connection or script URL."));
    });
  </script>
</body>
</html>
